@model List<StudentFacultyViewModel>

<h2>Danh sách sinh viên</h2>

<a href="/Student/Create">Thêm mới</a>

<table border="1">
    <tr>
        <th>Mã SV</th>
        <th>Họ tên</th>
        <th>Khoa</th>
        <th>Action</th>
    </tr>

@foreach (var item in Model)
{
    <tr>
        <td>@item.StudentID</td>
        <td>@item.FullName</td>
        <td>@item.FacultyName</td>
        <td>
            <a href="/Student/Edit/@item.StudentID">Sửa</a> |
            <a href="/Student/Delete/@item.StudentID">Xóa</a>
        </td>
    </tr>
}
</table>